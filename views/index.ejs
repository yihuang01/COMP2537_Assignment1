<%- include('template/header') %>

    <div class="container mt-5">
        <% if (!authenticated) { %>
            <div class="d-flex flex-column gap-2" style="width: fit-content;">
                <button class="btn btn-primary" onclick="location.href='/signup'">Sign up</button>
                <button class="btn btn-secondary" onclick="location.href='/login'">Log in</button>
            </div>
            <% } else { %>
                <div>
                    <h1>Hello, <%= name %>!</h1>
                </div>
                <div class="d-flex flex-column gap-2 mt-3" style="width: fit-content;">
                    <button class="btn btn-info" onclick="location.href='/members'">Go to Members Area</button>
                    <button class="btn btn-danger" onclick="location.href='/logout'">Logout</button>
                </div>
                <% } %>
    </div>

    <%- include('template/footer') %>